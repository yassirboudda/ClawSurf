[Desktop Entry]
Type=Application
Name=AMI Browser
GenericName=Web Browser
Comment=AI-powered automation browser with built-in chat, agents, and connections
Exec=$HOME/.local/bin/AMI-Browser %U
Icon=ami-browser
Terminal=false
Categories=Network;WebBrowser;
MimeType=text/html;text/xml;application/xhtml+xml;x-scheme-handler/http;x-scheme-handler/https;
StartupNotify=false
StartupWMClass=AMI-Browser
Keywords=ami;browser;automation;agent;ai;
