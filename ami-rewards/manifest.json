{
  "manifest_version": 3,
  "name": "AMI Rewards",
  "version": "1.0.0",
  "description": "Earn rewards for private ads you choose to see in AMI Browser. Get special benefits and discounts.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "externally_connectable": {
    "ids": ["*"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AMI Rewards — Coming Soon",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  }
}
