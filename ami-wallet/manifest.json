{
  "manifest_version": 3,
  "name": "AMI Wallet",
  "version": "1.0.0",
  "description": "Built-in crypto wallet for AMI Browser. Secure, self-custodial Web3 wallet with multi-chain support.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AMI Wallet",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["inpage-provider.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inpage-provider.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
